# Copy this file to .env and fill in the values. The .env file is git-ignored.

# Django secret key (generate a fresh one for any real deployment)
SECRET_KEY=change-me

# Debug mode (True in development, False in production)
DEBUG=True

# Comma-separated list of allowed hosts (used when DEBUG=False)
ALLOWED_HOSTS=

# Fernet key used to encrypt job-site passwords at rest (issue #366).
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CANDITRACK_FERNET_KEY=

# Shared token authenticating the Chrome extension (issue #2).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CANDITRACK_API_TOKEN=

# Chemin de la base SQLite (issue #17). Laisser vide en local (db.sqlite3 à la
# racine). En conteneur, docker-compose le pointe vers le volume persistant.
SQLITE_PATH=
